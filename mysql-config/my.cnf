[mysqld]
# Character set and collation
character-set-server = utf8mb4
collation-server = utf8mb4_0900_ai_ci
init_connect='SET NAMES utf8mb4'

# SQL modes (sane defaults)
sql_mode = STRICT_TRANS_TABLES,ERROR_FOR_DIVISION_BY_ZERO,NO_ZERO_DATE,NO_ZERO_IN_DATE,NO_ENGINE_SUBSTITUTION

# Lowercase table names for Windows host compatibility (case-insensitive)
lower_case_table_names = 1

# Connection/timeout tuning (safe locals)
max_connections = 200
timeout_query = 30
connect_timeout = 10
wait_timeout = 28800
interactive_timeout = 28800

# InnoDB settings (safe defaults)
innodb_buffer_pool_size = 256M
innodb_log_file_size = 128M
innodb_flush_log_at_trx_commit = 1
innodb_file_per_table = 1

# General
skip_name_resolve = 1
