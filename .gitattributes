# 줄바꿈 문자 설정
* text=auto
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.sh text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf

# 바이너리 파일
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.jar binary
*.war binary
*.ear binary

# Jenkins 파일
Jenkinsfile text eol=lf
**/Jenkinsfile text eol=lf
