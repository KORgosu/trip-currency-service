// 간단한 버전 - Python이 이미 설치되어 있다고 가정
pipeline {
    agent any

// 복잡한 버전 (Python 자동 설치 포함)
// pipeline {
//     agent any

    // Jenkins에 설정한 도구들
    tools {
        // SonarQube Scanner 도구
        'hudson.plugins.sonar.SonarRunnerInstallation' 'My SonarQube'
        // Python 도구 (Jenkins에 Python이 설치되어 있다면)
        // 'hudson.plugins.python.PythonInstallation' 'Python3'
    }

    // 환경 변수 설정
    environment {
        PYTHON_VERSION = '3.9'
        VIRTUAL_ENV = "${WORKSPACE}/services/currency-service/venv"
        PATH = "${VIRTUAL_ENV}/bin:${PATH}"
    }

    stages {
        // 1단계: GitHub에서 코드 가져오기
        stage('Checkout') {
            steps {
                checkout scm
                script {
                    // 작업 디렉토리로 이동
                    dir('services/currency-service') {
                        echo "Working directory: ${pwd()}"
                    }
                }
            }
        }

        // 2단계: Python 환경 설정
        stage('Setup Python Environment') {
            steps {
                dir('services/currency-service') {
                    sh '''
                        # Python 확인
                        echo "Checking Python installation..."
                        python3 --version || python --version || (echo "Python not found. Please install Python3 on Jenkins server." && exit 1)
                        
                        # 가상환경 생성
                        echo "Creating virtual environment..."
                        python3 -m venv venv || python -m venv venv
                        
                        # 가상환경 활성화 (. 명령어 사용)
                        . venv/bin/activate
                        echo "Virtual environment activated"
                        
                        # Python 및 pip 버전 확인
                        python --version
                        pip --version
                        
                        # 의존성 설치
                        echo "Installing dependencies..."
                        pip install --upgrade pip
                        pip install -r requirements.txt
                        echo "Dependencies installed successfully"
                    '''
                }
            }
        }

        // 3단계: SonarQube 코드 품질 분석
        stage('SonarQube Analysis') {
            steps {
                script {
                    def scannerHome = tool 'My SonarQube'
                    withSonarQubeEnv('My SonarQube') {
                        sh "'${scannerHome}/bin/sonar-scanner' -Dsonar.projectKey=trip-currency-service -Dsonar.sources=. -Dsonar.host.url=http://sonarqube:9000"
                    }
                }
            }
        }

    }

    post {
        always {
            script {
                try {
                    dir('services/currency-service') {
                        sh 'find . -type f -name "*.pyc" -delete || true'
                        sh 'find . -type d -name "__pycache__" -delete || true'
                    }
                } catch (Exception e) {
                    echo "Cleanup failed: ${e.getMessage()}"
                }
            }
        }
        
        success {
            echo 'Pipeline succeeded!'
            // 성공 시 알림 (Slack, Email 등)
        }
        
        failure {
            echo 'Pipeline failed!'
            // 실패 시 알림
        }
        
        unstable {
            echo 'Pipeline unstable!'
            // 불안정한 빌드 알림
        }
    }
}
